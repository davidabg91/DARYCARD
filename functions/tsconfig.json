{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitAny": true,
    "outDir": "lib",
    "preserveConstEnums": true,
    "removeComments": true,
    "sourceMap": true,
    "target": "es2020",
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["es2020", "esnext.disposable"],
    "skipLibCheck": true
  },
  "include": [
    "src"
  ]
}
