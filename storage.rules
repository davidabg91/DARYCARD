rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isStaff() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
            || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'moderator');
    }

    // Client photos. Readable by anyone (the public card-scan page shows the photo),
    // but only staff may upload, and only reasonably sized image files.
    match /client_photos/{file} {
      allow read: if true;
      allow write: if isStaff()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Everything else is locked down.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
